# MagicLight Auto — Environment Configuration
# Copy this file to .env and fill in your credentials

# ── Required ───────────────────────────────────────────────────────────────────
EMAIL=your@email.com
PASSWORD=yourpassword

# ── Google Sheets ──────────────────────────────────────────────────────────────
# Sheet ID from the URL: .../spreadsheets/d/{SHEET_ID}/edit
SHEET_ID=1MPfnJ2UajI-eKKqGS4y6eb3BEgXpJiZ44nr556cfXRE
SHEET_NAME=Database
# Path to your Google Service Account JSON credentials
CREDS_JSON=credentials.json

# ── Timing (seconds) — increase on slow connections ───────────────────────────
STEP1_WAIT=60
STEP2_WAIT=30
STEP3_WAIT=180
STEP4_RENDER_TIMEOUT=1200

# MagicLight Auto — Environment Configuration
# Copy this file to .env and fill in your credentials

# ── Required ───────────────────────────────────────────────────────────────────
EMAIL=your@email.com
PASSWORD=yourpassword

# ── Timing (seconds) — increase on slow connections ───────────────────────────
# Time to wait after submitting story (AI script generation)
STEP1_WAIT=60

# Time to wait for character/cast generation
STEP2_WAIT=30

# Max time to wait for storyboard images
STEP3_WAIT=180

# Max time to wait for final video render (default 20 min)
STEP4_RENDER_TIMEOUT=1200

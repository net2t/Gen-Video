# Environment Variables — copy this file to .env and fill in your credentials
# NEVER commit the real .env file — it is excluded by .gitignore

# ── Single account ──────────────────────────────────────────────────────────────
EMAIL=your@email.com
PASSWORD=yourpassword

# ── Multi-account (optional — overrides EMAIL/PASSWORD) ────────────────────────
# ACCOUNTS=user1@email.com:pass1,user2@email.com:pass2,user3@email.com:pass3

# ── Timing (optional — defaults shown) ─────────────────────────────────────────
# STEP1_WAIT=60           # seconds after story submission
# STEP2_WAIT=30           # seconds for character generation
# STEP3_WAIT=180          # max seconds for storyboard images
# STEP4_RENDER_TIMEOUT=1200  # max seconds for video render (20 min)
